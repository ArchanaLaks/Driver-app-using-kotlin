<?xml version="1.0" encoding="utf-8"?>

<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/teritoryColor"
    android:fitsSystemWindows="true">

    <!-- HEADER -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/primaryColor"
        android:fitsSystemWindows="true"
        app:elevation="0dp"
        android:stateListAnimator="@null">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbarNav"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="Close Trip"
            app:titleTextColor="@android:color/white"
            app:navigationIcon="@drawable/ic_back"
            app:navigationIconTint="@android:color/white"/>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- CONTENT -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- DROP -->
            <TextView
                android:id="@+id/tvDrop"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="16dp"
                android:text="Drop Location"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="@color/primaryColor"/>

            <!-- DISTANCE -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="16dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvDistanceNav"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="-- km"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvEtaNav"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="-- min"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- MAP FULL CONTROL -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="400dp"
                android:layout_margin="12dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="6dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <fragment
                        android:id="@+id/mapNav"
                        android:name="com.google.android.gms.maps.SupportMapFragment"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"/>

                    <!-- FLOATING BUTTON -->
                    <com.google.android.material.floatingactionbutton.FloatingActionButton
                        android:id="@+id/btnRecenter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom"
                        android:layout_margin="16dp"
                        android:src="@drawable/ic_my_location"
                        app:tint="@android:color/white"
                        app:backgroundTint="@color/primaryColor"/>

                </FrameLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- BUTTON -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnNavigate"
                android:layout_width="match_parent"
                android:layout_height="55dp"
                android:layout_margin="16dp"
                android:text="Open in Google Maps"
                android:textColor="@android:color/black"
                android:backgroundTint="@color/secondaryColor"/>


        </LinearLayout>
    </LinearLayout>

    <!-- SLIDER -->
    <com.ncorti.slidetoact.SlideToActView
        android:id="@+id/btnCompleteTrip"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_gravity="bottom"
        android:layout_margin="16dp"
        app:text="Swipe to Close"
        app:outer_color="@color/primaryColor"
        app:inner_color="@android:color/white"/>


</androidx.coordinatorlayout.widget.CoordinatorLayout>